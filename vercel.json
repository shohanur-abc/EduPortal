{
    "functions": {
        "src/app/api/**/*.ts": {
            "maxDuration": 60,
            "memory": 1024
        }
    },
    "headers": [
        {
            "source": "/api/:path*",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-store"
                }
            ]
        }
    ]
}